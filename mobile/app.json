{
  "expo": {
    "name": "Legal Ninja",
    "slug": "legal-ninja",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "legalninja",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#050A0F",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.legalninja.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in faster"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050A0F"
      },
      "package": "com.legalninja.app",
      "edgeToEdgeEnabled": true,
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        { "icon": "./assets/icon.png", "color": "#00F5FF" }
      ],
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
