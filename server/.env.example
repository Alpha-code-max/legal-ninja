# Server Configuration
NODE_ENV=production
PORT=3000
# Render automatically assigns a port, but you can override via environment

# Database
# MongoDB Atlas connection string (free tier available at https://www.mongodb.com/products/platform/atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/legal_ninja?retryWrites=true&w=majority
MONGODB_URI=

# Authentication
JWT_SECRET=change_this_to_a_strong_random_string_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# AI Provider Keys (set at least OPENAI_API_KEY for production)
# Get keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Google Gemini: https://makersuite.google.com/app/apikey
# - Groq: https://console.groq.com/keys
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=
GROQ_API_KEY=

# Payment Gateways
# Paystack: https://dashboard.paystack.com/
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...

# Flutterwave (optional): https://dashboard.flutterwave.com/
FLW_SECRET_KEY=FLWSECK_...
FLW_PUBLIC_KEY=FLWPUBK_...

# Admin Access Control
ADMIN_SECRET_KEY=generate_a_secure_random_hex_string

# Frontend CORS Configuration
# Update this to your deployed frontend URL
FRONTEND_URL=https://your-frontend-domain.com
